<?xml version="1.0"?>
<robot name="arm3dof">

  <material name="grey">
    <color rgba="0.4 0.4 0.4 1.0"/>
  </material>
  <material name="blue">
    <color rgba="0.2 0.4 0.8 1.0"/>
  </material>
  <material name="orange">
    <color rgba="0.9 0.5 0.1 1.0"/>
  </material>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.05"/>
      <geometry><cylinder radius="0.06" length="0.10"/></geometry>
      <material name="grey"/>
    </visual>
  </link>

  <joint name="joint1" type="revolute">
    <parent link="base_link"/>
    <child link="link1"/>
    <origin xyz="0 0 0.10"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.1416" upper="3.1416" effort="10" velocity="2"/>
  </joint>

  <link name="link1">
    <visual>
      <origin xyz="0 0 0.05"/>
      <geometry><cylinder radius="0.04" length="0.10"/></geometry>
      <material name="grey"/>
    </visual>
  </link>

  <joint name="joint2" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0 0 0.10"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.0944" upper="2.0944" effort="10" velocity="2"/>
  </joint>

  <link name="link2">
    <visual>
      <origin xyz="0 0 0.125"/>
      <geometry><box size="0.05 0.05 0.25"/></geometry>
      <material name="blue"/>
    </visual>
  </link>

  <joint name="joint3" type="revolute">
    <parent link="link2"/>
    <child link="link3"/>
    <origin xyz="0 0 0.25"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.618" upper="2.618" effort="10" velocity="2"/>
  </joint>

  <link name="link3">
    <visual>
      <origin xyz="0 0 0.125"/>
      <geometry><box size="0.04 0.04 0.25"/></geometry>
      <material name="blue"/>
    </visual>
    <visual>
      <origin xyz="0 0 0.265"/>
      <geometry><box size="0.05 0.05 0.03"/></geometry>
      <material name="orange"/>
    </visual>
  </link>

  <joint name="finger_left" type="prismatic">
    <parent link="link3"/>
    <child link="finger_l"/>
    <origin xyz="0 0.02 0.28"/>
    <axis xyz="0 1 0"/>
    <limit lower="0" upper="0.015" effort="5" velocity="0.1"/>
  </joint>

  <link name="finger_l">
    <visual>
      <origin xyz="0 0 0.02"/>
      <geometry><box size="0.012 0.008 0.04"/></geometry>
      <material name="orange"/>
    </visual>
  </link>

  <joint name="finger_right" type="prismatic">
    <parent link="link3"/>
    <child link="finger_r"/>
    <origin xyz="0 -0.02 0.28"/>
    <axis xyz="0 -1 0"/>
    <limit lower="0" upper="0.015" effort="5" velocity="0.1"/>
  </joint>

  <link name="finger_r">
    <visual>
      <origin xyz="0 0 0.02"/>
      <geometry><box size="0.012 0.008 0.04"/></geometry>
      <material name="orange"/>
    </visual>
  </link>

  <!-- the point the fingers close on - this is what the ik solves for -->
  <joint name="gripper_joint" type="fixed">
    <parent link="link3"/>
    <child link="gripper"/>
    <origin xyz="0 0 0.30"/>
  </joint>

  <link name="gripper"/>

</robot>
